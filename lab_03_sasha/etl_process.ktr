<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>lab_03_warehouse_variant3</name>
    <description/>
    <extended_description/>
    <trans_version/>
    <trans_type>Normal</trans_type>
    <directory>/</directory>
    <parameters></parameters>
    <log></log>
    <maxdate><connection/><table/><field/><offset>0.0</offset><maxdiff>0.0</maxdiff></maxdate>
    <size_rowset>10000</size_rowset>
    <sleep_time_empty>50</sleep_time_empty>
    <sleep_time_full>50</sleep_time_full>
    <unique_connections>N</unique_connections>
    <feedback_shown>Y</feedback_shown>
    <feedback_size>50000</feedback_size>
    <using_thread_priorities>Y</using_thread_priorities>
    <shared_objects_file/>
    <capture_step_performance>N</capture_step_performance>
    <step_performance_capturing_delay>1000</step_performance_capturing_delay>
    <step_performance_capturing_size_limit>100</step_performance_capturing_size_limit>
    <dependencies></dependencies>
    <partitionschemas></partitionschemas>
    <slaveservers></slaveservers>
    <clusterschemas></clusterschemas>
    <created_user>-</created_user>
    <created_date>2024/03/30 10:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2024/03/30 10:00:00.000</modified_date>
    <key_for_session_key/>
    <is_key_private>N</is_key_private>
  </info>

  <order>
    <hop><from>Table input (PostgreSQL retail_stores)</from><to>Filter Rows (store_balance &lt; 50)</to><enabled>Y</enabled></hop>
    <hop><from>Filter Rows (store_balance &lt; 50)</from><to>Stream Lookup (CSV Warehouse)</to><enabled>Y</enabled></hop>
    <hop><from>CSV input (main_warehouse.csv)</from><to>Stream Lookup (CSV Warehouse)</to><enabled>Y</enabled></hop>
    <hop><from>Stream Lookup (CSV Warehouse)</from><to>Stream Lookup (Excel Deliveries)</to><enabled>Y</enabled></hop>
    <hop><from>Excel input (deliveries.xlsx)</from><to>Stream Lookup (Excel Deliveries)</to><enabled>Y</enabled></hop>
    <hop><from>Stream Lookup (Excel Deliveries)</from><to>Calculator (discrepancy)</to><enabled>Y</enabled></hop>
    <hop><from>Calculator (discrepancy)</from><to>Table output (MySQL inventory_analysis)</to><enabled>Y</enabled></hop>
  </order>

  <step>
    <name>Table input (PostgreSQL retail_stores)</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>postgres_local</connection>
    <sql>SELECT store_id, product_id, store_balance, category FROM retail_stores</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <attributes/>
    <cluster_schema/>
    <remotesteps><input></input><output></output></remotesteps>
    <GUI><xloc>112</xloc><yloc>176</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Filter Rows (store_balance &lt; 50)</name>
    <type>FilterRows</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <send_true_to>Stream Lookup (CSV Warehouse)</send_true_to>
    <send_false_to/>
    <compare>
      <condition>
        <negated>N</negated>
        <leftvalue>store_balance</leftvalue>
        <function>&lt;</function>
        <rightvalue/>
        <value><name>constant</name><type>Integer</type><text>50</text><length>-1</length><precision>0</precision><isnull>N</isnull></value>
      </condition>
    </compare>
    <attributes/>
    <cluster_schema/>
    <remotesteps><input></input><output></output></remotesteps>
    <GUI><xloc>288</xloc><yloc>176</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>CSV input (main_warehouse.csv)</name>
    <type>CsvInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <filename>${Internal.Transformation.Filename.Directory}/main_warehouse.csv</filename>
    <filename_field/>
    <rownum_field/>
    <include_filename>N</include_filename>
    <separator>,</separator>
    <enclosure>&quot;</enclosure>
    <header>Y</header>
    <buffer_size>50000</buffer_size>
    <lazy_conversion>Y</lazy_conversion>
    <add_filename_result>N</add_filename_result>
    <parallel>N</parallel>
    <newline_possible>N</newline_possible>
    <format>mixed</format>
    <encoding/>
    <fields>
      <field><name>product_id</name><type>Integer</type><format>#</format><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type></field>
      <field><name>warehouse_balance</name><type>Integer</type><format>#</format><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type></field>
    </fields>
    <attributes/>
    <cluster_schema/>
    <remotesteps><input></input><output></output></remotesteps>
    <GUI><xloc>288</xloc><yloc>64</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Stream Lookup (CSV Warehouse)</name>
    <type>StreamLookup</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <from>CSV input (main_warehouse.csv)</from>
    <input_sorted>N</input_sorted>
    <preserve_memory>Y</preserve_memory>
    <sorted_list>N</sorted_list>
    <integer_pair>N</integer_pair>
    <lookup>
      <key><name>product_id</name><field>product_id</field></key>
      <value><name>warehouse_balance</name><rename>warehouse_balance</rename><default>0</default><type>Integer</type></value>
    </lookup>
    <attributes/>
    <cluster_schema/>
    <remotesteps><input></input><output></output></remotesteps>
    <GUI><xloc>448</xloc><yloc>176</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Excel input (deliveries.xlsx)</name>
    <type>ExcelInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <header>Y</header>
    <noempty>Y</noempty>
    <stoponempty>N</stoponempty>
    <filefield/>
    <sheetfield/>
    <sheetrownum_field/>
    <rownum_field/>
    <sheetname_field/>
    <file_required>N</file_required>
    <spreadsheet_type>SAX_POI</spreadsheet_type>
    <file>
      <name>${Internal.Transformation.Filename.Directory}/deliveries.xlsx</name>
      <filemask/>
      <exclude_filemask/>
      <file_required>N</file_required>
      <include_subfolders>N</include_subfolders>
    </file>
    <fields>
      <field><name>product_id</name><type>Integer</type><length>-1</length><precision>-1</precision><trim_type>none</trim_type></field>
      <field><name>delivery_qty</name><type>Integer</type><length>-1</length><precision>-1</precision><trim_type>none</trim_type></field>
    </fields>
    <attributes/>
    <cluster_schema/>
    <remotesteps><input></input><output></output></remotesteps>
    <GUI><xloc>448</xloc><yloc>64</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Stream Lookup (Excel Deliveries)</name>
    <type>StreamLookup</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <from>Excel input (deliveries.xlsx)</from>
    <input_sorted>N</input_sorted>
    <preserve_memory>Y</preserve_memory>
    <sorted_list>N</sorted_list>
    <integer_pair>N</integer_pair>
    <lookup>
      <key><name>product_id</name><field>product_id</field></key>
      <value><name>delivery_qty</name><rename>delivery_qty</rename><default>0</default><type>Integer</type></value>
    </lookup>
    <attributes/>
    <cluster_schema/>
    <remotesteps><input></input><output></output></remotesteps>
    <GUI><xloc>608</xloc><yloc>176</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Calculator (discrepancy)</name>
    <type>Calculator</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <calculation>
      <field_name>total_stock</field_name>
      <calc_type>ADD</calc_type>
      <field_a>store_balance</field_a>
      <field_b>warehouse_balance</field_b>
      <field_c/>
      <value_type>Integer</value_type>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <remove>N</remove>
    </calculation>
    <calculation>
      <field_name>discrepancy</field_name>
      <calc_type>SUBTRACT</calc_type>
      <field_a>total_stock</field_a>
      <field_b>delivery_qty</field_b>
      <field_c/>
      <value_type>Integer</value_type>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <remove>N</remove>
    </calculation>
    <attributes/>
    <cluster_schema/>
    <remotesteps><input></input><output></output></remotesteps>
    <GUI><xloc>768</xloc><yloc>176</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Table output (MySQL inventory_analysis)</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>mysql_remote</connection>
    <schema/>
    <table>inventory_analysis</table>
    <commit>1000</commit>
    <truncate>Y</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>N</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <return_keys>N</return_keys>
    <return_field/>
    <fields></fields>
    <attributes/>
    <cluster_schema/>
    <remotesteps><input></input><output></output></remotesteps>
    <GUI><xloc>944</xloc><yloc>176</yloc><draw>Y</draw></GUI>
  </step>
  
  <step_error_handling></step_error_handling>
  <slave-step-copy-partition-distribution></slave-step-copy-partition-distribution>
  <slave_transformation>N</slave_transformation>
  <attributes/>
</transformation>
