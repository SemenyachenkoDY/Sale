<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>lab_03_warehouse_variant3</name>
    <description>ETL Transformation for Warehouse Inventory (Variant 3)</description>
    <extended_description/>
    <trans_version/>
    <trans_type>Normal</trans_type>
    <directory>/</directory>
    <parameters></parameters>
    <log></log>
    <maxdate>
      <connection/>
      <table/>
      <field/>
      <offset>0.0</offset>
      <maxdiff>0.0</maxdiff>
    </maxdate>
    <size_rowset>10000</size_rowset>
    <sleep_time_empty>50</sleep_time_empty>
    <sleep_time_full>50</sleep_time_full>
    <unique_connections>N</unique_connections>
    <feedback_shown>Y</feedback_shown>
    <feedback_size>50000</feedback_size>
    <using_thread_priorities>Y</using_thread_priorities>
    <shared_objects_file/>
    <capture_step_performance>N</capture_step_performance>
    <step_performance_capturing_delay>1000</step_performance_capturing_delay>
    <step_performance_capturing_size_limit>100</step_performance_capturing_size_limit>
    <dependencies></dependencies>
    <partitionschemas></partitionschemas>
    <slaveservers></slaveservers>
    <clusterschemas></clusterschemas>
    <created_user>-</created_user>
    <created_date>2024/03/30 10:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2024/03/30 10:00:00.000</modified_date>
    <key_for_session_key/>
    <is_key_private>N</is_key_private>
  </info>
  <notepads>
    <notepad>
      <note>Variant 3: Warehouse. 
Filter: store_balance &lt; 50 to reduce 1M rows.
Calculation: discrepancy = (store_balance + warehouse) - deliveries</note>
      <xloc>64</xloc>
      <yloc>16</yloc>
      <width>400</width>
      <heigth>58</heigth>
    </notepad>
  </notepads>

  <order>
    <hop><from>Table input (PostgreSQL retail_stores)</from><to>Filter Rows (store_balance &lt; 50)</to><enabled>Y</enabled></hop>
    <hop><from>Filter Rows (store_balance &lt; 50)</from><to>Stream Lookup (CSV Warehouse)</to><enabled>Y</enabled></hop>
    <hop><from>CSV input (main_warehouse.csv)</from><to>Stream Lookup (CSV Warehouse)</to><enabled>Y</enabled></hop>
    <hop><from>Stream Lookup (CSV Warehouse)</from><to>Stream Lookup (Excel Deliveries)</to><enabled>Y</enabled></hop>
    <hop><from>Excel input (deliveries.xlsx)</from><to>Stream Lookup (Excel Deliveries)</to><enabled>Y</enabled></hop>
    <hop><from>Stream Lookup (Excel Deliveries)</from><to>Calculator (discrepancy)</to><enabled>Y</enabled></hop>
    <hop><from>Calculator (discrepancy)</from><to>Table output (MySQL inventory_analysis)</to><enabled>Y</enabled></hop>
  </order>

  <step>
    <name>Table input (PostgreSQL retail_stores)</name>
    <type>TableInput</type>
    <connection>postgres_local</connection>
    <sql>SELECT store_id, product_id, store_balance, category FROM retail_stores</sql>
    <GUI><xloc>100</xloc><yloc>150</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Filter Rows (store_balance &lt; 50)</name>
    <type>FilterRows</type>
    <condition>
      <leftvalue>store_balance</leftvalue>
      <function>&lt;</function>
      <rightvalue/>
      <value><name>constant</name><type>Integer</type><text>50</text><length>-1</length><precision>-1</precision><isnull>N</isnull></value>
    </condition>
    <GUI><xloc>250</xloc><yloc>150</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>CSV input (main_warehouse.csv)</name>
    <type>CsvInput</type>
    <filename>${Internal.Transformation.Filename.Directory}/main_warehouse.csv</filename>
    <separator>,</separator>
    <header>Y</header>
    <GUI><xloc>250</xloc><yloc>40</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Stream Lookup (CSV Warehouse)</name>
    <type>StreamLookup</type>
    <from>CSV input (main_warehouse.csv)</from>
    <lookup>
      <key><name>product_id</name><field>product_id</field></key>
      <value><name>warehouse_balance</name><rename>warehouse_balance</rename><default>0</default><type>Integer</type></value>
    </lookup>
    <GUI><xloc>400</xloc><yloc>150</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Excel input (deliveries.xlsx)</name>
    <type>ExcelInput</type>
    <file><name>${Internal.Transformation.Filename.Directory}/deliveries.xlsx</name></file>
    <fields>
      <field><name>product_id</name><type>Integer</type></field>
      <field><name>delivery_qty</name><type>Integer</type></field>
    </fields>
    <GUI><xloc>400</xloc><yloc>40</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Stream Lookup (Excel Deliveries)</name>
    <type>StreamLookup</type>
    <from>Excel input (deliveries.xlsx)</from>
    <lookup>
      <key><name>product_id</name><field>product_id</field></key>
      <value><name>delivery_qty</name><rename>delivery_qty</rename><default>0</default><type>Integer</type></value>
    </lookup>
    <GUI><xloc>550</xloc><yloc>150</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Calculator (discrepancy)</name>
    <type>Calculator</type>
    <calculation>
      <field_name>total_stock</field_name>
      <calc_type>ADD</calc_type>
      <field_a>store_balance</field_a>
      <field_b>warehouse_balance</field_b>
    </calculation>
    <calculation>
      <field_name>discrepancy</field_name>
      <calc_type>SUBTRACT</calc_type>
      <field_a>total_stock</field_a>
      <field_b>delivery_qty</field_b>
    </calculation>
    <GUI><xloc>700</xloc><yloc>150</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Table output (MySQL inventory_analysis)</name>
    <type>TableOutput</type>
    <connection>mysql_remote</connection>
    <table>inventory_analysis</table>
    <commit>1000</commit>
    <truncate>Y</truncate>
    <GUI><xloc>850</xloc><yloc>150</yloc><draw>Y</draw></GUI>
  </step>
</transformation>
