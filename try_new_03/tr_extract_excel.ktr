<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info><name>tr_extract_excel</name><trans_type>Normal</trans_type><directory>/</directory></info>
  <order>
    <hop><from>Get rows from result</from><to>Sort Rows - Result</to><enabled>Y</enabled></hop>
    <hop><from>Excel Input - Salaries</from><to>Sort Rows - Excel</to><enabled>Y</enabled></hop>
    <hop><from>Sort Rows - Result</from><to>Merge Join</to><enabled>Y</enabled></hop>
    <hop><from>Sort Rows - Excel</from><to>Merge Join</to><enabled>Y</enabled></hop>
    <hop><from>Merge Join</from><to>Copy rows to result</to><enabled>Y</enabled></hop>
  </order>

  <step>
    <name>Get rows from result</name>
    <type>RowsFromResult</type>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><type>none</type><schemaname/></partitioning>
    <fields>
      <field><name>emp_id</name><type>Integer</type></field>
      <field><name>last_name</name><type>String</type></field>
      <field><name>first_name</name><type>String</type></field>
      <field><name>middle_name</name><type>String</type></field>
    </fields>
    <GUI><xloc>100</xloc><yloc>50</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Excel Input - Salaries</name>
    <type>ExcelInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <type>none</type>
      <schemaname/>
    </partitioning>
    <spreadsheet_type>POI</spreadsheet_type>
    <file>
      <name>${Internal.Transformation.Filename.Directory}/data/salaries_source.xlsx</name>
      <filemask/>
      <exclude_filemask/>
      <file_required>N</file_required>
      <include_subfolders>N</include_subfolders>
    </file>
    <fields>
      <field>
        <name>emp_id</name>
        <type>Integer</type>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
        <format/>
        <currency/>
        <decimal/>
        <group/>
      </field>
      <field>
        <name>grade</name>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
        <format/>
        <currency/>
        <decimal/>
        <group/>
      </field>
      <field>
        <name>base_salary</name>
        <type>Number</type>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
        <format/>
        <currency/>
        <decimal/>
        <group/>
      </field>
      <field>
        <name>seniority_pct</name>
        <type>Number</type>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
        <format/>
        <currency/>
        <decimal/>
        <group/>
      </field>
      <field>
        <name>regional_coeff</name>
        <type>Number</type>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
        <format/>
        <currency/>
        <decimal/>
        <group/>
      </field>
      <field>
        <name>effective_date</name>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
        <format/>
        <currency/>
        <decimal/>
        <group/>
      </field>
      <field>
        <name>currency</name>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
        <format/>
        <currency/>
        <decimal/>
        <group/>
      </field>
    </fields>
    <sheets>
      <sheet>
        <name>Оклады</name>
        <startrow>0</startrow>
        <startcol>0</startcol>
      </sheet>
    </sheets>
    <header>Y</header>

    <strict_types>N</strict_types>
    <error_ignored>N</error_ignored>
    <error_line_skipped>N</error_line_skipped>
    <bad_line_files_destination_directory/>
    <bad_line_files_extension>warning</bad_line_files_extension>
    <error_line_files_destination_directory/>
    <error_line_files_extension>error</error_line_files_extension>
    <line_number_files_destination_directory/>
    <line_number_files_extension>line</line_number_files_extension>
    <shortFileFieldName/>
    <pathFieldName/>
    <hiddenFieldName/>
    <lastModificationTimeFieldName/>
    <uriNameFieldName/>
    <rootUriNameFieldName/>
    <extensionFieldName/>
    <sizeFieldName/>
    <spreadsheet_type>POI</spreadsheet_type>
    <GUI>
      <xloc>100</xloc>
      <yloc>150</yloc>
      <draw>Y</draw>
    </GUI>
  </step>


  <step>
    <name>Sort Rows - Result</name>
    <type>SortRows</type>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><type>none</type><schemaname/></partitioning>
    <fields><field><name>emp_id</name><ascending>Y</ascending></field></fields>
    <GUI><xloc>250</xloc><yloc>50</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Sort Rows - Excel</name>
    <type>SortRows</type>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><type>none</type><schemaname/></partitioning>
    <fields><field><name>emp_id</name><ascending>Y</ascending></field></fields>
    <GUI><xloc>250</xloc><yloc>150</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Merge Join</name>
    <type>MergeJoin</type>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><type>none</type><schemaname/></partitioning>
    <join_type>LEFT OUTER</join_type>
    <step1>Sort Rows - Result</step1>
    <step2>Sort Rows - Excel</step2>
    <keys_1><key>emp_id</key></keys_1>
    <keys_2><key>emp_id</key></keys_2>
    <GUI><xloc>400</xloc><yloc>100</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Copy rows to result</name>
    <type>RowsToResult</type>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><type>none</type><schemaname/></partitioning>
    <GUI><xloc>550</xloc><yloc>100</yloc><draw>Y</draw></GUI>
  </step>
</transformation>
