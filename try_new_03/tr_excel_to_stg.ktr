<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>tr_excel_to_stg</name>
    <description>Extract salaries from Excel and load into MySQL staging</description>
    <trans_type>Normal</trans_type>
    <directory>/</directory>
    <parameters></parameters>
    <size_rowset>10000</size_rowset>
    <sleep_time_empty>50</sleep_time_empty>
    <sleep_time_full>50</sleep_time_full>
    <unique_connections>N</unique_connections>
    <feedback_shown>Y</feedback_shown>
    <feedback_size>50000</feedback_size>
    <using_thread_priorities>Y</using_thread_priorities>
    <created_user>admin</created_user>
    <created_date>2026/03/31 13:30:00.000</created_date>
    <modified_user>admin</modified_user>
    <modified_date>2026/03/31 13:30:00.000</modified_date>
  </info>

  <connection>
    <name>MySQL_Target</name>
    <server>95.131.149.21</server>
    <type>MYSQL</type>
    <access>Native</access>
    <database>mgpu_ico_etl_XX</database>
    <port>3306</port>
    <username>YOUR_LOGIN</username>
    <password>YOUR_PASSWORD</password>
    <attributes>
      <attribute><code>PORT_NUMBER</code><attribute>3306</attribute></attribute>
      <attribute><code>EXTRA_OPTION_MYSQL.characterEncoding</code><attribute>UTF-8</attribute></attribute>
    </attributes>
  </connection>

  <order>
    <hop><from>Excel Input - Salaries</from><to>Table Output - stg_salaries</to><enabled>Y</enabled></hop>
  </order>

  <step>
    <name>Excel Input - Salaries</name>
    <type>ExcelInput</type>
    <header>Y</header>
    <noempty>Y</noempty>
    <stoponempty>N</stoponempty>
    <spreadsheet_type>POI</spreadsheet_type>
    <file>
      <name>${Internal.Transformation.Filename.Directory}/data/salaries_source.xlsx</name>
      <file_required>Y</file_required>
      <include_subfolders>N</include_subfolders>
    </file>
    <sheets>
      <sheet><name>Оклады</name><startrow>0</startrow><startcol>0</startcol></sheet>
    </sheets>
    <fields>
      <field><name>emp_id</name><type>Integer</type></field>
      <field><name>grade</name><type>String</type></field>
      <field><name>base_salary</name><type>Number</type></field>
      <field><name>seniority_pct</name><type>Number</type></field>
      <field><name>regional_coeff</name><type>Number</type></field>
      <field><name>effective_date</name><type>String</type></field>
      <field><name>currency</name><type>String</type></field>
    </fields>
    <GUI>
      <xloc>100</xloc>
      <yloc>100</yloc>
      <draw>Y</draw>
    </GUI>
  </step>

  <step>
    <name>Table Output - stg_salaries</name>
    <type>TableOutput</type>
    <connection>MySQL_Target</connection>
    <table>stg_salaries</table>
    <commit>10000</commit>
    <truncate>Y</truncate>
    <specify_fields>Y</specify_fields>
    <fields>
      <field><column_name>emp_id</column_name><stream_name>emp_id</stream_name></field>
      <field><column_name>grade</column_name><stream_name>grade</stream_name></field>
      <field><column_name>base_salary</column_name><stream_name>base_salary</stream_name></field>
      <field><column_name>seniority_pct</column_name><stream_name>seniority_pct</stream_name></field>
      <field><column_name>regional_coeff</column_name><stream_name>regional_coeff</stream_name></field>
      <field><column_name>effective_date</column_name><stream_name>effective_date</stream_name></field>
      <field><column_name>currency</column_name><stream_name>currency</stream_name></field>
    </fields>
    <GUI>
      <xloc>350</xloc>
      <yloc>100</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
</transformation>
