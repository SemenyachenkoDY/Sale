<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info><name>tr_extract_postgres</name><trans_type>Normal</trans_type><directory>/</directory></info>
  <connection>
    <name>PostgreSQL_Source</name>
    <server>localhost</server>
    <type>POSTGRESQL</type>
    <access>Native</access>
    <database>hr_data</database>
    <port>5432</port>
    <username>postgres</username>
    <password>Encrypted 2be98afc86aa7f2e4bb16bd64d980aac9</password>
  </connection>
  <order><hop><from>Table Input - Employees</from><to>Copy rows to result</to><enabled>Y</enabled></hop></order>

  <step>
    <name>Table Input - Employees</name>
    <type>TableInput</type>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><type>none</type><schemaname/></partitioning>
    <connection>PostgreSQL_Source</connection>
    <sql>SELECT emp_id, last_name, first_name, middle_name FROM employees_info WHERE is_active = TRUE</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <GUI><xloc>100</xloc><yloc>100</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Copy rows to result</name>
    <type>RowsToResult</type>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><type>none</type><schemaname/></partitioning>
    <GUI><xloc>300</xloc><yloc>100</yloc><draw>Y</draw></GUI>
  </step>
</transformation>
