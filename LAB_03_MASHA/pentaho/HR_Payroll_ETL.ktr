      <field><name>seniority_pct</name><rename/><length>-2</length><precision>-2</precision></field>
      <field><name>regional_coeff</name><rename/><length>-2</length><precision>-2</precision></field>
      <field><name>adjusted_salary</name><rename/><length>-2</length><precision>-2</precision></field>
      <field><name>bonus_amount</name><rename/><length>-2</length><precision>-2</precision></field>
      <field><name>bonus_type</name><rename/><length>-2</length><precision>-2</precision></field>
      <field><name>total_payout</name><rename/><length>-2</length><precision>-2</precision></field>
      <field><name>tax_ndfl</name><rename/><length>-2</length><precision>-2</precision></field>
      <field><name>tax_pension</name><rename/><length>-2</length><precision>-2</precision></field>
      <field><name>tax_medical</name><rename/><length>-2</length><precision>-2</precision></field>
      <field><name>tax_social</name><rename/><length>-2</length><precision>-2</precision></field>
      <field><name>net_payout</name><rename/><length>-2</length><precision>-2</precision></field>
      <field><name>employer_cost</name><rename/><length>-2</length><precision>-2</precision></field>
    </fields>
    <select_unspecified>N</select_unspecified>
    <GUI>
      <xloc>1250</xloc>
      <yloc>450</yloc>
      <draw>Y</draw>
    </GUI>
  </step>

