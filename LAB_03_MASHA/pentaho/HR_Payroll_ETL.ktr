      <field><column_name>seniority_pct</column_name><stream_name>seniority_pct</stream_name></field>
      <field><column_name>regional_coeff</column_name><stream_name>regional_coeff</stream_name></field>
      <field><column_name>adjusted_salary</column_name><stream_name>adjusted_salary</stream_name></field>
